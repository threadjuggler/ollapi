# Copy this file to .env and adjust as needed:  cp .env.example .env

# --- Postgres ---
POSTGRES_USER=ollapi
POSTGRES_PASSWORD=REDACTED
POSTGRES_DB=ollapi

# --- App ---
# Port the web UI is published on (browse to http://localhost:8000)
APP_PORT=8000

# Ollama model to use. The default is Gemma 4 E2B. You can change it here or
# live from the Settings panel in the UI. Examples: llama3.2:1b, qwen2.5:3b
OLLAMA_MODEL=gemma4:e2b

# Automatically download the model on first startup (true/false)
AUTO_PULL_MODEL=true
