# Copy this file to .env and adjust as needed:  cp .env.example .env

# --- Postgres ---
# REQUIRED: set a strong password below. There is intentionally no default, so
# that no credential is ever committed to the repo. docker-compose will refuse
# to start while this is empty.
POSTGRES_USER=ollapi
POSTGRES_PASSWORD=
POSTGRES_DB=ollapi

# --- Database URL (local / non-Docker dev only) ---
# In Docker this is built automatically from the POSTGRES_* values above. To run
# the app directly with uvicorn, set the full URL here instead:
# DATABASE_URL=postgresql+asyncpg://ollapi:<your-password>@localhost:5431/ollapi

# --- App ---
# Port the web UI is published on (browse to http://localhost:8000)
APP_PORT=8000

# Ollama model to use. The default is Gemma 4 E2B. You can change it here or
# live from the Settings panel in the UI. Examples: llama3.2:1b, qwen2.5:3b
OLLAMA_MODEL=gemma4:e2b

# Automatically download the model on first startup (true/false)
AUTO_PULL_MODEL=true
